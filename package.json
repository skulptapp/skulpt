{
    "name": "skulpt-app",
    "main": "index.ts",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "db:generate": "bunx drizzle-kit generate",
        "lint": "bunx expo lint",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:ci": "jest --runInBand --silent",
        "verify": "bun run lint && bun run typecheck && bun run test:ci",
        "prebuild:ios": "expo prebuild -p ios --clean",
        "prebuild:android": "expo prebuild -p android --clean",
        "build:ios": "eas build --platform ios --profile development",
        "build:android": "eas build --platform android --profile development",
        "release:ios": "eas build --platform ios --auto-submit",
        "release:android": "eas build --platform android --auto-submit",
        "update:all": "eas update --channel production --environment production && npx sentry-expo-upload-sourcemaps dist",
        "locale": "tsx ./scripts/translations.ts"
    },
    "jest": {
        "preset": "jest-expo",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1"
        }
    },
    "expo": {
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "lodash",
                    "@appmetrica/react-native-analytics",
                    "nanoid",
                    "nanoid-dictionary",
                    "qs",
                    "immer",
                    "react-number-format"
                ]
            }
        },
        "install": {
            "exclude": [
                "@sentry/react-native",
                "react-native-reanimated",
                "react-native-worklets"
            ]
        }
    },
    "dependencies": {
        "@appmetrica/react-native-analytics": "^4.1.0",
        "@bacons/apple-targets": "^4.0.7",
        "@expo/metro-runtime": "~57.0.3",
        "@gorhom/bottom-sheet": "^5.2.14",
        "@hookform/resolvers": "^5.4.0",
        "@kingstinct/react-native-healthkit": "^14.0.2",
        "@react-native-community/datetimepicker": "9.1.0",
        "@react-native-community/hooks": "^100.1.0",
        "@react-native-community/slider": "5.2.0",
        "@sentry/react-native": "^8.18.0",
        "@shopify/flash-list": "2.0.2",
        "@tanstack/react-query": "^5.101.2",
        "axios": "^1.18.1",
        "dayjs": "^1.11.21",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "dset": "^3.1.4",
        "expo": "^57.0.4",
        "expo-application": "~57.0.0",
        "expo-asset": "~57.0.3",
        "expo-audio": "~57.0.0",
        "expo-background-task": "~57.0.2",
        "expo-constants": "~57.0.3",
        "expo-dev-client": "~57.0.5",
        "expo-device": "~57.0.0",
        "expo-file-system": "~57.0.0",
        "expo-font": "~57.0.0",
        "expo-haptics": "~57.0.0",
        "expo-health-connect": "^0.1.1",
        "expo-image": "~57.0.0",
        "expo-keep-awake": "~57.0.0",
        "expo-linear-gradient": "~57.0.0",
