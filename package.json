{
    "name": "skulpt-app",
    "main": "index.ts",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "db:generate": "bunx drizzle-kit generate",
        "lint": "bunx expo lint",
        "prebuild": "expo prebuild -p ios --clean",
        "build:ios": "eas build --platform ios --profile development",
        "build:android": "eas build --platform android --profile development",
        "release:ios": "eas build --platform ios --auto-submit",
        "release:android": "eas build --platform android --auto-submit",
        "update:all": "eas update --channel production --environment production && npx sentry-expo-upload-sourcemaps dist",
        "locale": "tsx ./scripts/translations.ts"
    },
    "jest": {
        "preset": "jest-expo",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1"
        }
    },
    "expo": {
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "lodash",
                    "@appmetrica/react-native-analytics",
                    "nanoid",
                    "nanoid-dictionary",
                    "qs",
                    "immer",
                    "react-number-format"
                ]
            }
        },
        "install": {
            "exclude": [
                "@sentry/react-native"
            ]
        }
    },
    "dependencies": {
        "@appmetrica/react-native-analytics": "^3.6.0",
        "@bacons/apple-targets": "^4.0.7",
        "@expo/metro-runtime": "^56.0.12",
