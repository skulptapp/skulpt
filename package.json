        "expo-notifications": "~57.0.3",
        "expo-router": "~57.0.4",
        "expo-screen-orientation": "~57.0.0",
        "expo-sharing": "~57.0.3",
        "expo-splash-screen": "~57.0.2",
        "expo-sqlite": "~57.0.0",
        "expo-status-bar": "~57.0.0",
        "expo-store-review": "~57.0.0",
        "expo-system-ui": "~57.0.0",
        "expo-task-manager": "~57.0.2",
        "expo-updates": "~57.0.6",
        "fuse.js": "^7.5.0",
        "i18next": "^26.3.6",
        "immer": "^11.1.11",
