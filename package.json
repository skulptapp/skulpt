{
    "name": "skulpt-app",
    "main": "index.ts",
    "scripts": {
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "db:generate": "bunx drizzle-kit generate",
        "lint": "bunx expo lint",
        "prebuild": "expo prebuild -p ios --clean",
        "build:ios": "eas build --platform ios --profile development",
        "build:android": "eas build --platform android --profile development",
        "release:ios": "eas build --platform ios --auto-submit",
        "release:android": "eas build --platform android --auto-submit",
        "update:all": "eas update --channel production --environment production && npx sentry-expo-upload-sourcemaps dist",
        "locale": "tsx ./scripts/translations.ts",
        "postinstall": "patch-package"
    },
    "jest": {
        "preset": "jest-expo",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1"
        }
    },
    "expo": {
        "doctor": {
            "reactNativeDirectoryCheck": {
                "exclude": [
                    "lodash",
                    "@appmetrica/react-native-analytics",
                    "nanoid",
                    "nanoid-dictionary",
                    "qs",
                    "immer",
                    "react-number-format"
                ]
            }
        },
        "install": {
            "exclude": [
                "@sentry/react-native"
            ]
        }
    },
    "dependencies": {
        "@appmetrica/react-native-analytics": "^3.6.0",
        "@bacons/apple-targets": "^4.0.6",
        "@expo/metro-runtime": "^55.0.9",
        "@gorhom/bottom-sheet": "^5.2.9",
        "@hookform/resolvers": "^5.2.2",
        "@kingstinct/react-native-healthkit": "^14.0.0",
        "@react-native-community/datetimepicker": "8.6.0",
        "@react-native-community/hooks": "^100.1.0",
        "@react-native-community/slider": "5.1.2",
        "@react-navigation/native": "^7.1.33",
        "@react-navigation/stack": "^7.8.10",
        "@sentry/react-native": "^8.7.0",
        "@shopify/flash-list": "2.0.2",
        "@tanstack/react-query": "^5.99.0",
        "axios": "^1.15.0",
        "dayjs": "^1.11.20",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "dset": "^3.1.4",
        "expo": "^55.0.15",
        "expo-application": "^55.0.14",
        "expo-asset": "^55.0.15",
        "expo-audio": "^55.0.13",
        "expo-background-task": "^55.0.16",
        "expo-constants": "^55.0.14",
        "expo-dev-client": "^55.0.27",
        "expo-device": "^55.0.15",
        "expo-file-system": "^55.0.16",
        "expo-font": "^55.0.6",
        "expo-haptics": "^55.0.14",
        "expo-health-connect": "^0.1.1",
        "expo-keep-awake": "^55.0.6",
