        "babel-plugin-inline-import": "^3.0.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "^0.31.10",
        "eslint-config-expo": "^57.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "expo-build-properties": "^57.0.3",
        "expo-drizzle-studio-plugin": "^0.2.1",
        "fs-extra": "^11.3.6",
        "jest": "~29.7.0",
        "jest-expo": "^57.0.1",
        "prettier": "^3.9.5",
        "react-test-renderer": "^19.2.7",
        "tsx": "^4.23.1",
        "typescript": "~6.0.3"
    },
    "overrides": {
        "zod-validation-error": "4.0.2"
    },
    "trustedDependencies": [
        "@sentry/cli"
    ],
    "patchedDependencies": {
        "@bacons/xcode@1.0.0-alpha.32": "patches/@bacons%2Fxcode@1.0.0-alpha.32.patch"
    }
