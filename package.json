        "dayjs": "^1.11.20",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "dset": "^3.1.4",
        "expo": "^56.0.4",
        "expo-application": "^56.0.3",
        "expo-asset": "^56.0.14",
        "expo-audio": "^56.0.10",
