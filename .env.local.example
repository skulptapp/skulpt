# Environment: development | preview | production
# Copy this file to .env.local and fill in the values

# --------------------------------------------------
# App identity
# --------------------------------------------------

# App display name (shown on home screen)
APP_NAME=Skulpt

# App version (semver major.minor)
APP_VERSION=1.0

# Incremental build number (integer, e.g. unix timestamp)
APP_BUILD_NUMBER=1

# Bundle identifier — must match your provisioning profile / Play Console entry
# Convention: app.skulpt.development | app.skulpt.preview | app.skulpt
APP_BUNDLE_IDENTIFIER=app.skulpt.development

# Build variant: development | preview | production
# Controls dev icon, Sentry project, and other per-environment behavior
APP_VARIANT=development

# --------------------------------------------------
# Apple (iOS builds & App Store submission)
# --------------------------------------------------

# Apple ID email used for App Store Connect submission
APP_APPLE_ID=

# Apple Developer Team ID (10-character string, find at developer.apple.com/account)
APP_APPLE_TEAM_ID=

# App Store Connect app ID (numeric, find in App Store Connect > App Information)
APP_ASC_APP_ID=

# --------------------------------------------------
# Expo / EAS
# --------------------------------------------------

# EAS project ID (uuid, find at expo.dev project settings)
APP_EAS_PROJECT_ID=

# --------------------------------------------------
# Analytics
# --------------------------------------------------

# AppMetrica API key (get from appmetrica.yandex.com)
EXPO_PUBLIC_APPMETRICA_API_KEY=

# PostHog project API key and host
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --------------------------------------------------
# Error tracking (Sentry)
# --------------------------------------------------

# Sentry DSN for runtime error reporting (find in Sentry project settings > Client Keys)
EXPO_PUBLIC_SENTRY_DSN=

# Sentry organization and project slugs (used for source map uploads during build)
APP_SENTRY_ORGANIZATION=
APP_SENTRY_PROJECT=

# Sentry auth token with project:releases and org:read scopes
# Generate at sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# --------------------------------------------------
# Sync server
# --------------------------------------------------

# Base URL of the sync API server
EXPO_PUBLIC_SYNC_HOST=http://localhost:3000
