+    moveCopyBuildPhaseBeforePostEmbedScripts(phase) {
+        const phases = this.props.buildPhases;
+        const currentIndex = phases.indexOf(phase);
+        if (currentIndex === -1) {
+            return;
+        }
+        const postEmbedScriptIndex = phases.findIndex((candidate) => {
+            if (!PBXSourcesBuildPhase_1.PBXShellScriptBuildPhase.is(candidate)) {
+                return false;
+            }
+            return (candidate.props.name ===
+                "[Expo Dev Launcher] Strip Local Network Keys for Release" ||
+                candidate.props.name === "Upload Debug Symbols to Sentry" ||
+                candidate.props.name === "[CP] Embed Pods Frameworks");
+        });
+        if (postEmbedScriptIndex === -1 || postEmbedScriptIndex >= currentIndex) {
+            return;
+        }
+        phases.splice(currentIndex, 1);
+        phases.splice(postEmbedScriptIndex, 0, phase);
+    }
