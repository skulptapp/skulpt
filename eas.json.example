{
    "cli": {
        "version": ">= 16.17.3",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "environment": "development",
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "environment": "preview",
            "distribution": "internal",
            "channel": "preview"
        },
        "production": {
            "environment": "production",
            "channel": "production"
        }
    },
    "submit": {
        "production": {
            "android": {
                "track": "internal",
                "releaseStatus": "completed"
            },
            "ios": {
                "appleId": "",
                "ascAppId": "",
                "appleTeamId": ""
            }
        }
    }
}
